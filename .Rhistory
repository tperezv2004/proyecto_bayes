library(tidyverse)
library(lubridate)
library(skimr)
ruta_datos <- "Data/completos.csv"
df <- read_csv(ruta_datos)
df_trabajo <- df_limpio %>%
filter(Country == pais_trabajo)
df_trabajo %>%
count(Sex)
df_trabajo %>%
count(Event, sort = TRUE)
df_trabajo %>%
count(Equipment, sort = TRUE)
df_trabajo %>%
count(WeightClassKg, sort = TRUE)
ggplot(df_trabajo, aes(x = Dots)) +
geom_histogram(bins = 30, color = "white") +
labs(
title = paste("Distribucion del puntaje DOTS en atletas de", pais_trabajo),
x = "Puntaje DOTS",
y = "Frecuencia"
) +
theme_minimal()
ggplot(df_trabajo, aes(x = Sex, y = Dots)) +
geom_boxplot() +
labs(
title = paste("Puntaje DOTS segun sexo en", pais_trabajo),
x = "Sexo",
y = "Puntaje DOTS"
) +
theme_minimal()
ggplot(df_trabajo, aes(x = Equipment, y = Dots)) +
geom_boxplot() +
labs(
title = paste("Puntaje DOTS segun equipamiento en", pais_trabajo),
x = "Equipamiento",
y = "Puntaje DOTS"
) +
theme_minimal()
ggplot(df_trabajo, aes(x = Age, y = Dots)) +
geom_point(alpha = 0.25) +
labs(
title = paste("Relacion entre edad y DOTS en", pais_trabajo),
x = "Edad",
y = "Puntaje DOTS"
) +
theme_minimal()
library(tidyverse)
library(lubridate)
library(skimr)
ruta_datos <- "Data/completos.csv"
df <- read_csv(ruta_datos)
dim(df)
head(df)
names(df)
df_seleccion <- df %>%
select(
# Identificacion
Name,
# Variables del atleta
Sex,
Age,
AgeClass,
BirthYearClass,
BodyweightKg,
WeightClassKg,
# Tipo de competencia
Event,
Equipment,
Division,
Tested,
# Levantamientos principales
Best3SquatKg,
Best3BenchKg,
Best3DeadliftKg,
TotalKg,
# Puntajes de rendimiento
Dots,
Wilks,
Goodlift,
# Resultado competitivo
Place,
# Informacion geografica del atleta
Country,
State,
# Informacion de la competencia
Federation,
ParentFederation,
Date,
MeetCountry,
MeetState,
MeetTown,
MeetName,
Sanctioned
)
dim(df_seleccion)
head(df_seleccion)
df_limpio <- df_seleccion %>%
drop_na(
Sex,
Event,
Equipment,
Age,
BodyweightKg,
Best3DeadliftKg,
TotalKg,
Dots,
Country,
Date
)
dim(df_seleccion)
dim(df_limpio)
df_limpio %>%
count(Sex)
df_limpio %>%
count(Event, sort = TRUE)
df_limpio %>%
count(Equipment, sort = TRUE)
df_limpio %>%
count(es_chileno = Country == "Chile")
df_limpio %>%
count(Country, sort = TRUE) %>%
head(20)
df_limpio %>%
count(es_chileno = Country == "Chile") # SON MUY POCOS CHILENOS?
pais_trabajo <- "USA"
df_trabajo <- df_limpio %>%
filter(Country == pais_trabajo)
dim(df_trabajo)
df_trabajo %>%
count(Sex)
df_trabajo %>%
count(Event, sort = TRUE)
df_trabajo %>%
count(Equipment, sort = TRUE)
df_trabajo %>%
count(WeightClassKg, sort = TRUE)
hist(
df_trabajo$Dots,
breaks = 30,
main = paste("Distribucion del puntaje DOTS en atletas de", pais_trabajo),
xlab = "Puntaje DOTS",
ylab = "Frecuencia"
)
boxplot(
Dots ~ Sex,
data = df_trabajo,
main = paste("Puntaje DOTS segun sexo en", pais_trabajo),
xlab = "Sexo",
ylab = "Puntaje DOTS"
)
boxplot(
Dots ~ Equipment,
data = df_trabajo,
main = paste("Puntaje DOTS segun equipamiento en", pais_trabajo),
xlab = "Equipamiento",
ylab = "Puntaje DOTS"
)
plot(
df_trabajo$BodyweightKg,
df_trabajo$Dots,
main = paste("Relacion entre peso corporal y DOTS en", pais_trabajo),
xlab = "Peso corporal (kg)",
ylab = "Puntaje DOTS"
)
plot(
df_trabajo$Age,
df_trabajo$Dots,
main = paste("Relacion entre edad y DOTS en", pais_trabajo),
xlab = "Edad",
ylab = "Puntaje DOTS"
)
boxplot(
Best3DeadliftKg ~ Equipment,
data = df_trabajo,
main = paste("Peso muerto segun equipamiento en", pais_trabajo),
xlab = "Equipamiento",
ylab = "Mejor peso muerto registrado (kg)"
)
boxplot(
Best3DeadliftKg ~ Equipment,
data = df_trabajo,
main = paste("Peso muerto segun equipamiento en", pais_trabajo),
xlab = "Equipamiento",
ylab = "Mejor peso muerto registrado (kg)"
)
# Propuesta de Proyecto: Rendimiento en Powerlifting
## Contexto del problema
El powerlifting es un deporte de fuerza en el que los atletas compiten principalmente en tres movimientos: sentadilla, press banca y peso muerto. El rendimiento puede medirse de distintas formas: por kilogramos levantados en cada ejercicio, por el total levantado o por puntajes ajustados por peso corporal, como DOTS.
# --------------------------------------------------------
# --------------------------------------------------------
# 1. LIBRERIAS
# --------------------------------------------------------
# --------------------------------------------------------
library(tidyverse)
library(lubridate)
library(skimr)
# --------------------------------------------------------
# --------------------------------------------------------
# 2. CARGAR BASE DE DATOS
# --------------------------------------------------------
# --------------------------------------------------------
ruta_datos <- "Data/completos.csv"
df <- read_csv(ruta_datos)
# Propuesta de Proyecto: Rendimiento en Powerlifting
## Contexto del problema
El powerlifting es un deporte de fuerza en el que los atletas compiten principalmente en tres movimientos: sentadilla, press banca y peso muerto. El rendimiento puede medirse de distintas formas: por kilogramos levantados en cada ejercicio, por el total levantado o por puntajes ajustados por peso corporal, como DOTS.
# --------------------------------------------------------
# --------------------------------------------------------
# 1. LIBRERIAS
# --------------------------------------------------------
# --------------------------------------------------------
library(tidyverse)
library(lubridate)
library(skimr)
# --------------------------------------------------------
# --------------------------------------------------------
# 2. CARGAR BASE DE DATOS
# --------------------------------------------------------
# --------------------------------------------------------
ruta_datos <- "Data/completos.csv"
df <- read_csv(ruta_datos)
# --------------------------------------------------------
# --------------------------------------------------------
# 1. LIBRERIAS
# --------------------------------------------------------
# --------------------------------------------------------
library(tidyverse)
library(lubridate)
library(skimr)
# --------------------------------------------------------
# --------------------------------------------------------
# 2. CARGAR BASE DE DATOS
# --------------------------------------------------------
# --------------------------------------------------------
ruta_datos <- "Data/completos.csv"
df <- read_csv(ruta_datos)
# --------------------------------------------------------
# --------------------------------------------------------
# 3. REVUSION INICIAL
# --------------------------------------------------------
# --------------------------------------------------------
dim(df)
head(df)
names(df)
# --------------------------------------------------------
# --------------------------------------------------------
# 4. SELECCION DE COLUMNAS (cambiar? revisar README.txt en carpeta datos)
# --------------------------------------------------------
# --------------------------------------------------------
df_seleccion <- df %>%
select(
# Identificacion
Name,
# Variables del atleta
Sex,
Age,
AgeClass,
BirthYearClass,
BodyweightKg,
WeightClassKg,
# Tipo de competencia
Event,
Equipment,
Division,
Tested,
# Levantamientos principales
Best3SquatKg,
Best3BenchKg,
Best3DeadliftKg,
TotalKg,
# Puntajes de rendimiento
Dots,
Wilks,
Goodlift,
# Resultado competitivo
Place,
# Informacion geografica del atleta
Country,
State,
# Informacion de la competencia
Federation,
ParentFederation,
Date,
MeetCountry,
MeetState,
MeetTown,
MeetName,
Sanctioned
)
dim(df_seleccion)
head(df_seleccion)
# --------------------------------------------------------
# --------------------------------------------------------
# 5. BORRARS NULOS
# --------------------------------------------------------
# --------------------------------------------------------
df_limpio <- df_seleccion %>%
drop_na(
Sex,
Event,
Equipment,
Age,
BodyweightKg,
Best3DeadliftKg,
TotalKg,
Dots,
Country,
Date
)
dim(df_seleccion)
dim(df_limpio)
# --------------------------------------------------------
# --------------------------------------------------------
# 6. REVISAR DATOS LIMPIA
# --------------------------------------------------------
# --------------------------------------------------------
df_limpio %>%
count(Sex)
df_limpio %>%
count(Event, sort = TRUE)
df_limpio %>%
count(Equipment, sort = TRUE)
df_limpio %>%
count(es_chileno = Country == "Chile")
df_limpio %>%
count(Country, sort = TRUE) %>%
head(20)
df_limpio %>%
count(es_chileno = Country == "Chile") # SON MUY POCOS CHILENOS?
# --------------------------------------------------------
# --------------------------------------------------------
# 7. PASI A TRABAJAR
# --------------------------------------------------------
# --------------------------------------------------------
pais_trabajo <- "USA"
# pais_trabajo <- "Chile"
df_trabajo <- df_limpio %>%
filter(Country == pais_trabajo)
dim(df_trabajo)
df_trabajo %>%
count(Sex)
df_trabajo %>%
count(Event, sort = TRUE)
df_trabajo %>%
count(Equipment, sort = TRUE)
df_trabajo %>%
count(WeightClassKg, sort = TRUE)
# --------------------------------------------------------
# --------------------------------------------------------
# 8. GRAFICOS
# --------------------------------------------------------
# --------------------------------------------------------
# Grafico 1: Distribucion del puntaje DOTS
hist(
df_trabajo$Dots,
breaks = 30,
main = paste("Distribucion del puntaje DOTS en atletas de", pais_trabajo),
xlab = "Puntaje DOTS",
ylab = "Frecuencia"
)
# Grafico 2: Puntaje DOTS segun sexo
boxplot(
Dots ~ Sex,
data = df_trabajo,
main = paste("Puntaje DOTS segun sexo en", pais_trabajo),
xlab = "Sexo",
ylab = "Puntaje DOTS"
)
# Grafico 3: Puntaje DOTS segun equipamiento
boxplot(
Dots ~ Equipment,
data = df_trabajo,
main = paste("Puntaje DOTS segun equipamiento en", pais_trabajo),
xlab = "Equipamiento",
ylab = "Puntaje DOTS"
)
# Grafico 4: Relacion entre peso corporal y DOTS
plot(
df_trabajo$BodyweightKg,
df_trabajo$Dots,
main = paste("Relacion entre peso corporal y DOTS en", pais_trabajo),
xlab = "Peso corporal (kg)",
ylab = "Puntaje DOTS"
)
# Grafico 5: Relacion entre edad y DOTS
plot(
df_trabajo$Age,
df_trabajo$Dots,
main = paste("Relacion entre edad y DOTS en", pais_trabajo),
xlab = "Edad",
ylab = "Puntaje DOTS"
)
# Grafico 6: Peso muerto segun equipamiento
boxplot(
Best3DeadliftKg ~ Equipment,
data = df_trabajo,
main = paste("Peso muerto segun equipamiento en", pais_trabajo),
xlab = "Equipamiento",
ylab = "Mejor peso muerto registrado (kg)"
)
df_limpio <- df_seleccion %>%
drop_na(
# Identificacion
Name,
# Variables del atleta
Sex,
Age,
AgeClass,
BirthYearClass,
BodyweightKg,
WeightClassKg,
# Tipo de competencia
Event,
Equipment,
Division,
Tested,
# Levantamientos principales
Best3SquatKg,
Best3BenchKg,
Best3DeadliftKg,
TotalKg,
# Puntajes de rendimiento
Dots,
Wilks,
Goodlift,
# Resultado competitivo
Place,
# Informacion geografica del atleta
Country,
State,
# Informacion de la competencia
Federation,
ParentFederation,
Date,
MeetCountry,
MeetState,
MeetTown,
MeetName,
Sanctioned
)
dim(df_seleccion)
dim(df_limpio)
pais_trabajo <- "USA"
# pais_trabajo <- "Chile"
df_trabajo <- df_limpio %>%
filter(Country == pais_trabajo)
dim(df_trabajo)
write.csv(df_trabajo, "datos_trabajo.csv", row.names = FALSE)
