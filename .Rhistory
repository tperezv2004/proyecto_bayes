print(p7)
df_trabajo %>%
filter(Sex %in% c("M", "F")) %>%
# Calculamos proporciones para las etiquetas
group_by(Sex, Elite) %>%
summarise(n = n(), .groups = "drop_last") %>%
mutate(prop = n / sum(n)) %>%
ggplot(aes(x = Sex, y = prop, fill = Elite)) +
geom_col(position = "fill", width = 0.7) +
# Añadimos etiquetas de porcentaje sobre las barras
geom_text(aes(label = percent(prop, accuracy = 0.1)),
position = position_stack(vjust = 0.5),
color = "white", fontface = "bold") +
scale_y_continuous(labels = percent) +
scale_fill_manual(values = c("No" = "#E4645C", "Si" = "#2D8B92"),
labels = c("No Élite", "Élite")) +
labs(
title = "Proporción de Atletas Élite por Sexo en USA",
subtitle = "Justificación: ¿Es el sexo un factor determinante para alcanzar el nivel Élite?",
x = "Sexo (Categoría de Competición)",
y = "Porcentaje de Atletas",
fill = "Nivel"
) +
theme_minimal(base_size = 14) +
theme(
legend.position = "top",
panel.grid.major.x = element_blank()
)
